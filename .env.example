# Application
NEXT_PUBLIC_APP_NAME="Signal Archive"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_DESCRIPTION="Save meaningful things from the internet. Organize them into collections called Frequencies."
MAX_USERS="2"
APP_ORIGIN="http://localhost:3000"
API_ORIGIN="http://localhost:3000"
FILE_ORIGIN="http://localhost:3000"
PREVIEW_ORIGIN="http://localhost:3000"

# Database
DATABASE_URL="file:./dev.db"

# Auth
AUTH_SECRET="your-super-secret-auth-secret-change-in-production-min-32-chars"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Email (optional - for password reset, verification)
EMAIL_SERVER_HOST="smtp.example.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="user@example.com"
EMAIL_SERVER_PASSWORD="password"
EMAIL_FROM="Signal Archive <noreply@signal-archive.local>"

# Local file storage. Use an absolute persistent path on a VPS.
UPLOAD_DIR="./public/uploads"
MAX_FILE_SIZE="10485760" # 10MB

# Link Preview Service (optional)
LINK_PREVIEW_API_KEY=""
LINK_PREVIEW_TIMEOUT="5000"

# Background Jobs (optional - for cron/queues)
CRON_SECRET="your-cron-secret"

# Feature Flags
NEXT_PUBLIC_ENABLE_GHOST_MODE="true"
NEXT_PUBLIC_ENABLE_RESEARCH_TRAILS="true"
NEXT_PUBLIC_ENABLE_LINK_PREVIEWS="true"
NEXT_PUBLIC_ENABLE_PRIVATE_ENV="true"

# Internal test environment (disabled by default; never enable in production)
ENABLE_TEST_ENVIRONMENT="false"
ALLOWED_TEST_HOSTS="localhost,127.0.0.1"

# Owner-only Reflection Mapper. Targets must be explicitly authorized here.
ENABLE_TEST_LAB="false"
TEST_LAB_ALLOWED_HOSTS=""

# Rate Limiting
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX_REQUESTS="100"

# Security
CSP_REPORT_URI=""
ENABLE_SCENARIO_LAB=false
