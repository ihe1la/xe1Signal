generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String              @id @default(cuid())
  email             String              @unique
  emailVerified     DateTime?
  name              String?
  username          String              @unique
  displayName       String?
  bio               String?
  avatarUrl         String?
  bannerUrl         String?
  currentMood       String              @default("low light / private")
  passwordHash      String?
  role              String              @default("USER")
  isActive          Boolean             @default(true)
  isBanned          Boolean             @default(false)
  bannedAt          DateTime?
  bannedReason      String?
  lastActiveAt      DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  // Relations
  accounts          Account[]
  sessions          Session[]
  resetTokens       PasswordResetToken[]
  signals           Signal[]            @relation("SignalOwner")
  frequencies       Frequency[]         @relation("FrequencyOwner")
  collaborations    FrequencyCollaborator[]
  followedFrequencies FrequencyFollow[]
  reactions         Reaction[]
  comments          Comment[]           @relation("CommentAuthor")
  mentions          Comment[]           @relation("CommentMentions")
  saves             SavedSignal[]
  sentMessages      Message[]           @relation("SentMessages")
  receivedMessages  Message[]           @relation("ReceivedMessages")
  notifications     Notification[]
  followers         Follow[]            @relation("Following")
  following         Follow[]            @relation("Follower")
  blocks            Block[]             @relation("Blocker")
  blockedBy         Block[]             @relation("Blocked")
  reports           Report[]            @relation("Reporter")
  reported          Report[]            @relation("Reported")
  trails            ResearchTrail[]     @relation("TrailOwner")
  trailCollaborations ResearchTrailCollaborator[]
  settings          UserSettings?
  auditLogs         AuditLog[]

  @@index([username])
  @@index([email])
  @@index([role])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserSettings {
  id                    String   @id @default(cuid())
  userId                String   @unique
  emailNotifications    Boolean  @default(true)
  pushNotifications     Boolean  @default(true)
  showActivityStatus    Boolean  @default(true)
  showOnlineStatus      Boolean  @default(false)
  defaultSignalVisibility String @default("PUBLIC")
  defaultFrequencyVisibility String @default("PUBLIC")
  theme                 String   @default("dark")
  language              String   @default("en")
  timezone              String   @default("UTC")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Signal {
  id                String            @id @default(cuid())
  ownerId           String
  type              String
  title             String?
  content           String?
  description       String?
  sourceUrl         String?
  sourceDomain      String?
  previewImageUrl   String?
  previewData       String?
  mediaProvider     String?
  mediaEntityType   String?
  externalId        String?
  providerUri       String?
  creatorName       String?
  thumbnailUrl      String?
  durationMs        Int?
  metadataJson      String?
  tags              String            @default("")
  frequencyId       String?
  visibility        String            @default("PUBLIC")
  selectedUserIds   String            @default("")
  signalStrength    Int               @default(0)
  reactionCount     Int               @default(0)
  commentCount      Int               @default(0)
  saveCount         Int               @default(0)
  viewCount         Int               @default(0)
  ghostMode         String?
  ghostModeExpiresAt DateTime?
  ghostModeOpenedAt DateTime?
  ghostModeOpenedBy String?
  relatedSignalIds  String            @default("")
  isArchived        Boolean           @default(false)
  isDraft           Boolean           @default(false)
  frequencyOrder    Int               @default(0)
  isDeleted         Boolean           @default(false)
  deletedAt         DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // Relations
  owner             User              @relation("SignalOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  frequency         Frequency?        @relation(fields: [frequencyId], references: [id], onDelete: SetNull)
  files             SignalFile[]
  reactions         Reaction[]
  comments          Comment[]
  saves             SavedSignal[]
  
  // Self-relation for related signals
  relatedTo         Signal[]          @relation("SignalRelations")
  relatedFrom       Signal[]          @relation("SignalRelations")
  
  trailNodes        ResearchTrailNode[]

  @@index([ownerId])
  @@index([frequencyId])
  @@index([type])
  @@index([visibility])
  @@index([createdAt])
  @@index([signalStrength])
  @@index([tags])
  @@index([sourceDomain])
  @@index([mediaProvider])
  @@index([externalId])
  @@index([ghostModeExpiresAt])
  @@index([isArchived])
  @@index([isDeleted])
}

model SignalFile {
  id          String   @id @default(cuid())
  signalId    String
  filename    String
  originalName String
  mimeType    String
  size        Int
  url         String
  thumbnailUrl String?
  width       Int?
  height      Int?
  duration    Float?  // for audio/video
  order       Int     @default(0)
  createdAt   DateTime @default(now())

  signal Signal @relation(fields: [signalId], references: [id], onDelete: Cascade)

  @@index([signalId])
}

model Frequency {
  id          String              @id @default(cuid())
  ownerId     String
  name        String
  description String?
  coverImageUrl String?
  tags        String              @default("")
  visibility  String              @default("PUBLIC")
  signalCount Int                 @default(0)
  followerCount Int               @default(0)
  isArchived  Boolean             @default(false)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  // Relations
  owner           User              @relation("FrequencyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  signals         Signal[]
  collaborators   FrequencyCollaborator[]
  followers       FrequencyFollow[]

  @@index([ownerId])
  @@index([visibility])
  @@index([name])
  @@index([tags])
}

model FrequencyCollaborator {
  id          String           @id @default(cuid())
  frequencyId String
  userId      String
  role        String           @default("EDITOR")
  invitedAt   DateTime         @default(now())
  acceptedAt  DateTime?
  createdAt   DateTime         @default(now())

  frequency Frequency @relation(fields: [frequencyId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([frequencyId, userId])
  @@index([userId])
}

model FrequencyFollow {
  id          String   @id @default(cuid())
  frequencyId String
  userId      String
  createdAt   DateTime @default(now())

  frequency Frequency @relation(fields: [frequencyId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([frequencyId, userId])
  @@index([userId])
}

model Reaction {
  id        String        @id @default(cuid())
  userId    String
  signalId  String
  type      String        @default("STAR")
  createdAt DateTime      @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  signal Signal @relation(fields: [signalId], references: [id], onDelete: Cascade)

  @@unique([userId, signalId, type])
  @@index([signalId])
  @@index([userId])
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  signalId  String
  parentId  String?
  content   String
  isEdited  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User     @relation("CommentAuthor", fields: [userId], references: [id], onDelete: Cascade)
  signal   Signal   @relation(fields: [signalId], references: [id], onDelete: Cascade)
  parent   Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")
  mentions User[]   @relation("CommentMentions")

  @@index([signalId])
  @@index([userId])
  @@index([parentId])
}

model SavedSignal {
  id        String   @id @default(cuid())
  userId    String
  signalId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  signal Signal @relation(fields: [signalId], references: [id], onDelete: Cascade)

  @@unique([userId, signalId])
  @@index([userId])
  @@index([signalId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  reason    String?
  createdAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model Message {
  id        String   @id @default(cuid())
  senderId  String
  receiverId String
  content   String
  isRead    Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  data      String?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model Report {
  id        String   @id @default(cuid())
  reporterId String
  reportedId String
  reason    String
  details   String?
  status    String   @default("PENDING") // PENDING, REVIEWED, RESOLVED, DISMISSED
  resolvedBy String?
  resolvedAt DateTime?
  createdAt DateTime @default(now())

  reporter User @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reported User @relation("Reported", fields: [reportedId], references: [id], onDelete: Cascade)

  @@index([reporterId])
  @@index([reportedId])
  @@index([status])
}

model ResearchTrail {
  id          String         @id @default(cuid())
  ownerId     String
  title       String
  description String?
  visibility  String          @default("PRIVATE")
  nodeCount   Int            @default(0)
  viewCount   Int            @default(0)
  isArchived  Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  owner       User              @relation("TrailOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  nodes       ResearchTrailNode[]
  collaborators ResearchTrailCollaborator[]
  connections ResearchTrailConnection[]

  @@index([ownerId])
  @@index([visibility])
}

model ResearchTrailNode {
  id        String   @id @default(cuid())
  trailId   String
  signalId  String?
  type      String   // SIGNAL, NOTE, DIVIDER
  title     String?
  content   String?
  positionX Float    @default(0)
  positionY Float    @default(0)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trail  ResearchTrail @relation(fields: [trailId], references: [id], onDelete: Cascade)
  signal Signal?       @relation(fields: [signalId], references: [id], onDelete: SetNull)
  
  sourceConnections ResearchTrailConnection[] @relation("SourceConnections")
  targetConnections ResearchTrailConnection[] @relation("TargetConnections")

  @@index([trailId])
  @@index([signalId])
}

model ResearchTrailConnection {
  id        String   @id @default(cuid())
  trailId   String
  sourceId  String
  targetId  String
  label     String?
  createdAt DateTime @default(now())

  trail  ResearchTrail @relation(fields: [trailId], references: [id], onDelete: Cascade)
  source ResearchTrailNode @relation("SourceConnections", fields: [sourceId], references: [id], onDelete: Cascade)
  target ResearchTrailNode @relation("TargetConnections", fields: [targetId], references: [id], onDelete: Cascade)

  @@index([trailId])
}

model ResearchTrailCollaborator {
  id        String   @id @default(cuid())
  trailId   String
  userId    String
  role      String           @default("EDITOR")
  createdAt DateTime @default(now())

  trail ResearchTrail @relation(fields: [trailId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([trailId, userId])
}

model LinkPreview {
  id          String   @id @default(cuid())
  url         String   @unique
  title       String?
  description String?
  image       String?
  siteName    String?
  favicon     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([url])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  entityType  String?
  entityId    String?
  details     String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model SearchIndex {
  id          String   @id @default(cuid())
  entityType  String   // SIGNAL, USER, FREQUENCY
  entityId    String   @unique
  content     String
  metadata    String?
  lastIndexedAt DateTime @default(now())

  @@index([entityType])
}
